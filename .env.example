# Database
DATABASE_URL=./statup.db
DB_MAX_CONNECTIONS=10

# Server
HOST=0.0.0.0
PORT=3000

# Security (REQUIRED - generate with: openssl rand -base64 32)
SESSION_SECRET=your-secret-key-at-least-32-characters-long

# Session
SESSION_EXPIRY=604800  # 7 days in seconds

# Logging
LOG_LEVEL=info  # trace, debug, info, warn, error
RUST_LOG=statup=info,tower_http=info

# Public mode - read-only pages accessible without login (default: false)
PUBLIC_MODE=false

# Initial admin (optional, used only on first run)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=secure-initial-password
